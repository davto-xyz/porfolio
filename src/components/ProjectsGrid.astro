---
import { getCollection } from 'astro:content';
import Title from './Title.astro';

const allProjects = await getCollection('projects');

const projects = allProjects.sort((a, b) => {
  if (a.data.order && b.data.order) {
    return a.data.order - b.data.order;
  }
  return a.data.title.localeCompare(b.data.title);
});
---

<section id="projects" class="py-20 min-h-screen flex items-center">
  <div class="w-full">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="w-full flex justify-center">
        <Title title="Proyectos" />
      </div>
      <p class="text-xl mt-6 w-full leading-relaxed text-gray-800 font-stretch-expanded tracking-tighter">
        Soluciones digitales reales, diseñadas y desarrolladas con tecnologías modernas
      </p>
    </div>

    <!-- Projects Grid - 2 columns -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-16 justify-center items-stretch w-full lg:grid-rows-1">
      {projects.map((project) => {
        return (
          <div class="experience-card bg-[#E3E2DC]/70 rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 group relative overflow-hidden w-full hover:bg-[#ebeae4]">
            <!-- Background Gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-gold-500/5 group-hover:to-gold-500/10 transition-all duration-300 border-3 rounded-3xl border-gray-950"></div>

            <!-- Content -->
            <div class="p-8 relative z-10 flex flex-col space-y-4 h-full lg:min-h-[500px]">
              <!-- Header Section -->
              <div class="flex-shrink-0">
                <div class="mb-2">
                  <h3 class="font-stretch-ultra-expanded font-black text-3xl text-gray-950 group-hover:text-gold-500 transition-colors duration-300 text-center mb-4">
                    {project.data.title}
                  </h3>

                  <!-- Tag Badge -->
                  <div class="flex flex-wrap gap-2 mt-4 justify-center">
                    <span class="px-3 py-1 bg-gold-500 text-gray-950 text-base font-bold uppercase rounded-full shadow-sm hover:bg-gold-600 transition-colors duration-200 border-2 border-gray-850 tracking-tighter">
                      {project.data.tag}
                    </span>
                  </div>
                </div>
              </div>

              <!-- Description -->
              <div class="flex-grow">
                <p class="text-gray-800 text-base leading-relaxed">
                  {project.data.description}
                </p>
              </div>

              <!-- Technologies + Link -->
              <div class="flex-shrink-0 pt-4 flex items-center justify-between gap-4">
                {project.data.technologies && (
                  <div class="flex flex-wrap gap-2">
                    {project.data.technologies.map((tech) => (
                      <span class="px-3 py-1 text-gray-950 text-xs 2xl:text-sm rounded-full font-medium bg-white hover:text-grey-950 transition-colors duration-200 border-2 border-gray-950">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}

                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center text-gray-950 font-bold hover:text-gold-600 hover:scale-105 transition-all duration-300 text-sm group/link tracking-tighter flex-shrink-0"
                  >
                    VER PROYECTO
                    <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7"></path>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
